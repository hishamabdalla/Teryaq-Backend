<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <!--
    Adds a wildcard catch-all so ALL packages can restore from nuget.org,
    supplementing the explicit patterns in the global NuGet.Config.
  -->
  <packageSourceMapping>
    <packageSource key="nuget.org">
      <package pattern="*" />
    </packageSource>
  </packageSourceMapping>
</configuration>
